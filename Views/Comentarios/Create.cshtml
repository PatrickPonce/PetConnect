@model PetConnect.Models.Comentario

<h3>Dejar comentario (corregido para compilar)</h3>

<form asp-action="Create" method="post">
    
    <!-- 
        NOTA: Por ahora, ocultaremos los campos de ID. 
        Más adelante, el controlador se encargará de asignar el UsuarioId del usuario logueado
        y el NoticiaId de la noticia que se está comentando.
        Esto se hace para permitir que el proyecto compile.
    -->
    <input type="hidden" asp-for="UsuarioId" />
    <input type="hidden" asp-for="NoticiaId" />

    <div class="form-group">
        @* CAMBIO: Se cambió asp-for="Texto" por asp-for="Contenido" *@
        <label asp-for="Contenido">Comentario</label>
        <textarea asp-for="Contenido" class="form-control"></textarea>
    </div>

    <button class="btn btn-primary" type="submit">Enviar comentario</button>
</form>